# Scraper configuration — copy to .env and adjust

CRAWLER_ENABLED=true
CRAWLER_HEADLESS=true
CRAWLER_USER_AGENT=TechnopolisPriceTracker/1.0 (+https://localhost; personal research)
CRAWLER_MIN_DELAY_MS=1500
CRAWLER_MAX_DELAY_MS=3000
CRAWLER_CONCURRENCY=2
CRAWLER_DEEP_CRAWL=false
CRAWLER_CATEGORY_URLS=https://www.technopolis.bg/bg/c/Promotions
CRAWLER_OUTPUT_DIR=../crawl_output
CRAWLER_MAX_PAGES=1
